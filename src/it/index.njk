<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div>
      <p class="hero-eyebrow fade-up">Alaskan Malamute — Guida Completa</p>
      <h1 class="hero-title fade-up fade-up-1">
        Tutto quello<br>che <em>devi sapere</em><br>sul Malamute.
      </h1>
      <p class="hero-desc fade-up fade-up-2">
        Che tu stia valutando di prendere un cucciolo o che il tuo Malamute sia già di casa, qui trovi guide pratiche, consigli basati sull'esperienza diretta e tutto ciò che serve per vivere bene con questa razza straordinaria.
      </p>
      <a href="#categorie" class="hero-cta fade-up fade-up-3">
        Esplora le guide
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="hero-image-wrap fade-up fade-up-2">
      <div class="hero-placeholder">
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="32" cy="20" r="10"/>
          <path d="M16 54c0-8.8 7.2-16 16-16s16 7.2 16 16"/>
          <path d="M8 32c0-4.4 3.6-8 8-8M56 32c0-4.4-3.6-8-8-8"/>
        </svg>
        <span>Foto in arrivo</span>
      </div>
    </div>
  </div>
</section>

<!-- CATEGORIES -->
