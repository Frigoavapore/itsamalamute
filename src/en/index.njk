<!-- LATEST POSTS -->
<section class="latest-section">
  <div class="container">
    <p class="section-label">From the blog</p>
    <h2 class="section-title">Latest articles</h2>
    <p class="section-sub">First-hand experiences, practical guides and updates.</p>

    <div class="posts-grid">
      {% set recentPosts = collections.en_posts | reverse | slice(0, 6) %}
      {% if recentPosts and recentPosts.length > 0 %}
        {% for post in recentPosts %}
        <a href="{{ post.url }}" class="post-card">
          <div class="post-card-image">
            {% if post.data.cover %}
              <img src="{{ post.data.cover }}" alt="{{ post.data.title }}" loading="lazy">
            {% else %}
              <div class="post-card-placeholder">🐾</div>
            {% endif %}
          </div>
          <div class="post-card-body">
            <div class="post-card-cat">{{ post.data.category or "Article" }}</div>
            <h3 class="post-card-title">{{ post.data.title }}</h3>
            {% if post.data.description %}
            <p class="post-card-excerpt">{{ post.data.description }}</p>
            {% endif %}
            <div class="post-card-meta">{{ post.date | readableDate }}</div>
          </div>
        </a>
        {% endfor %}
      {% else %}
        <div class="post-card">
          <div class="post-card-image"><div class="post-card-placeholder">🐺</div></div>
          <div class="post-card-body">
            <div class="post-card-cat">The Breed</div>
            <h3 class="post-card-title">Alaskan Malamute temperament: what to expect</h3>
            <p class="post-card-excerpt">Intelligent, independent and affectionate: discover the true Malamute temperament before bringing one home.</p>
            <div class="post-card-meta">Coming soon</div>
          </div>
        </div>
        <div class="post-card">
          <div class="post-card-image"><div class="post-card-placeholder">🎯</div></div>
          <div class="post-card-body">
            <div class="post-card-cat">Training</div>
            <h3 class="post-card-title">How to train a Malamute puppy: beginner's guide</h3>
            <p class="post-card-excerpt">First commands, leash manners and how to build trust from day one with your new puppy.</p>
            <div class="post-card-meta">Coming soon</div>
          </div>
        </div>
        <div class="post-card">
          <div class="post-card-image"><div class="post-card-placeholder">🏥</div></div>
          <div class="post-card-body">
            <div class="post-card-cat">Health</div>
            <h3 class="post-card-title">Hip dysplasia in Malamutes: symptoms and prevention</h3>
            <p class="post-card-excerpt">One of the most common conditions in the breed: how to spot it early and what steps to take.</p>
            <div class="post-card-meta">Coming soon</div>
          </div>
        </div>
      {% endif %}
    </div>

    <div class="view-all-wrap">
      <a href="/en/blog/" class="btn-outline">
        All articles
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
