---
layout: base-en.njk
---
<section class="cat-hero">
  <div class="container cat-hero-inner">
    <p class="cat-hero-eyebrow">It's A Malamute</p>
    <h1 class="cat-hero-title">{{ title }}</h1>
    {% if description %}<p class="cat-hero-desc">{{ description }}</p>{% endif %}
  </div>
</section>

<nav class="breadcrumb">
  <div class="container breadcrumb-inner">
    <a href="/en/">Home</a>
    <span class="breadcrumb-sep">›</span>
    <span>{{ title }}</span>
  </div>
</nav>

<section class="cat-posts-section">
  <div class="container">
    {% if posts and posts.length > 0 %}
    <div class="posts-grid">
      {% for post in posts %}
      <a href="{{ post.url }}" class="post-card">
        <div class="post-card-image">
          {% if post.data.cover %}
            <img src="{{ post.data.cover }}" alt="{{ post.data.title }}" loading="lazy">
          {% else %}
            <div class="post-card-placeholder">{{ catIcon or "🐾" }}</div>
          {% endif %}
        </div>
        <div class="post-card-body">
          <div class="post-card-cat">{{ post.data.category or title }}</div>
          <h2 class="post-card-title">{{ post.data.title }}</h2>
          {% if post.data.description %}
          <p class="post-card-excerpt">{{ post.data.description }}</p>
          {% endif %}
          <div class="post-card-meta">{{ post.date | readableDate }}</div>
        </div>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div style="text-align:center; padding: 80px 0; color: var(--text-light);">
      <p style="font-family: var(--ff-mono); font-size:0.8rem; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:12px;">Coming soon</p>
      <p style="font-family: var(--ff-display); font-size: 1.5rem; color: var(--arctic);">Articles on their way.</p>
      <p style="margin-top:12px; font-size:0.95rem;">Come back soon for the first guides on this topic.</p>
    </div>
    {% endif %}
  </div>
</section>
